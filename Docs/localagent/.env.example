# ── LLM ─────────────────────────────────────────────────────────────────────
OLLAMA_HOST=host.docker.internal
OLLAMA_PORT=11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT=120

# ── Telegram ──────────────────────────────────────────────────────────────────
# Get token from @BotFather
TELEGRAM_TOKEN=8091894593:AAEV9ZB7vade3HVIYghISwu0E-zKAQjvj0k
# Get your ID from @userinfobot (comma-separated for multiple users)
ALLOWED_CHAT_IDS=-5148806294cd

# ── Workspace ─────────────────────────────────────────────────────────────────
WORKSPACE_ROOT=/workspace

# ── Scheduler ─────────────────────────────────────────────────────────────────
HEARTBEAT_INTERVAL_SEC=1800
IDLE_NUDGE_HOURS=2
TASK_REMINDER_HORIZON_HOURS=24

# ── Network allowlist (comma-separated domains) ───────────────────────────────
ALLOWED_DOMAINS=api.telegram.org

# ── RSS feeds (comma-separated URLs) ─────────────────────────────────────────
RSS_FEEDS=

# ── Agent limits ──────────────────────────────────────────────────────────────
MAX_TOOL_ROUNDS=3
MAX_CONTEXT_MESSAGES=20
SHELL_TIMEOUT_SEC=30
CODE_EXEC_TIMEOUT_SEC=15
